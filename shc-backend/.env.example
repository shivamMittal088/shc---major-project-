JWT_SECRET_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS_MODE=starttls
SMTP_DIAL_TIMEOUT_SECONDS=10
SMTP_USER=
SMTP_FROM_EMAIL=
SMTP_PASSWORD=
GOOGLE_APP_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
R2_BUCKET_NAME=
R2_TOKEN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_REGION=
# Optional generic S3-compatible override (for local MinIO/dev):
# If S3_ENDPOINT_URL is set, backend uses S3_* vars first, then falls back to R2_* keys.
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_ACCESS_KEY_SECRET=
S3_REGION=
REDIS_URL=
PORT=

# Risk scoring microservice integration
RISK_ML_SERVICE_URL=http://localhost:8081
RISK_SERVICE_TIMEOUT_MS=4000
RISK_SCORE_CACHE_TTL_SECONDS=300

# Storage mode: "object" (default, uses R2/S3) or "local" (stores files on disk, no paid bucket needed)
SHC_STORAGE_MODE=
# Local directory used when SHC_STORAGE_MODE=local (relative paths are resolved from shc-backend root)
SHC_LOCAL_STORAGE_DIR=
# Optional public base URL for generated local upload/download links
BACKEND_PUBLIC_BASE_URL=
